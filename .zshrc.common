# Shared completion setup
autoload -Uz compinit
zstyle ':completion:*' completer _expand _complete _ignored
zstyle ':completion:*' matcher-list \
  'm:{[:lower:]}={[:upper:]} m:{[:lower:][:upper:]}={[:upper:][:lower:]}' \
  'r:|[._-]=* r:|=*' '' 'l:|=* r:|=*' \
  'm:{a-zA-Z}={A-Za-z}'
compinit -C
setopt COMPLETE_IN_WORD
unsetopt MENU_COMPLETE
setopt NO_CASE_GLOB
setopt beep extendedglob notify

# History settings
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY

# Keybindings
bindkey -v
bindkey -M viins 'jk' vi-cmd-mode
bindkey '^R' history-incremental-search-backward

# Aliases
alias e="clear && ${EDITOR:-nvim}"
alias x="exit"
alias ls="exa --icons"
alias glogol="git log --oneline"
alias tma="tmux attach"
alias gpr="gh pr"
alias gco="git branch | fzf-tmux --prompt 'checkout: ' -w 75% -h 50% --preview 'git log --oneline --color=always {1}' | xargs git checkout"
alias grb="git branch | fzf-tmux --prompt 'rebase onto: ' -w 75% -h 50% --preview 'git log --oneline --color=always {1}' | xargs git rebase"
alias gdel="git branch | fzf-tmux --prompt 'delete: ' -w 75% -h 50% --preview 'git log --oneline --color=always {1}' | xargs git branch -D"
alias lg="lazygit"
alias db="nvim -c :DBUI"
alias pnpx="pnpm dlx"
alias gyatt="git"

# Paths
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
export PATH="$HOME/.pgenv/bin:$HOME/.pgenv/pgsql/bin:$PATH"
export PATH="$HOME/.opencode/bin:$PATH"
export PATH="$HOME/.sst/bin:$PATH"
if [[ -n "${PNPM_HOME:-}" ]]; then
  case ":$PATH:" in
    *":$PNPM_HOME:") ;;
    *) export PATH="$PNPM_HOME:$PATH" ;;
  esac
fi

# Other variables
export EDITOR="nvim"
# For everything-claude-code (see: https://github.com/affaan-m/everything-claude-code#hook-runtime-controls)
export ECC_HOOK_PROFILE="minimal"
export ECC_SESSION_START_MAX_CHARS=4000

export PYENV_ROOT="$HOME/.pyenv"
if [[ -d "$PYENV_ROOT/bin" ]]; then
  export PATH="$PYENV_ROOT/bin:$PATH"
fi
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init -)"
fi

export DOCKER_DEFAULT_PLATFORM=linux/amd64

# Tool inits and completions
if [[ -n "$BUN_INSTALL" && -s "$BUN_INSTALL/_bun" ]]; then
  source "$BUN_INSTALL/_bun"
fi

if command -v ng >/dev/null 2>&1; then
  source <(ng completion script)
fi

if command -v ngrok >/dev/null 2>&1; then
  eval "$(ngrok completion)"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

fnm_paths=(
  "$HOME/.local/share/fnm"
  "$HOME/.fnm"
  "/opt/homebrew/bin"
)

if ! command -v fnm >/dev/null 2>&1; then
  for fnm_dir in "${fnm_paths[@]}"; do
    if [[ -d "$fnm_dir" ]]; then
      case ":$PATH:" in
        *":$fnm_dir:"*) ;;
        *) export PATH="$fnm_dir:$PATH" ;;
      esac
    fi
  done
fi

if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env)"
fi
